{
  "author": "Fabio Pereira <fabio@fabiopereira.dev>",
  "name": "marky",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "description": "Apostrophe-inspired Markdown editor built with Electron, React, and TypeScript.",
  "scripts": {
    "dev": "tsx ./scripts/dev.ts",
    "build": "tsx ./scripts/build.ts",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux AppImage dir",
    "build:all": "npm run build && electron-builder --win --mac --linux",
    "preview": "tsx ./scripts/preview.ts",
    "lint": "eslint .",
    "typecheck": "tsx ./scripts/typecheck.ts",
    "format": "prettier --write .",
    "check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test",
    "commitlint": "commitlint --edit",
    "postinstall": "tsx ./scripts/postinstall.ts",
    "prepare": "tsx ./scripts/prepare.ts"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.3.4",
    "@codemirror/language": "^6.0.0",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.2",
    "@uiw/react-codemirror": "^4.25.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.6.2",
    "lucide-react": "^0.511.0",
    "mermaid": "^11.12.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rehype-stringify": "^10.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tailwind-merge": "^3.3.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^9.39.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/typography": "^0.5.16",
    "@types/hast": "^3.0.4",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.21",
    "electron": "^41.0.2",
    "electron-builder": "^26.0.0",
    "electron-vite": "^4.0.0",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.18",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^7.2.1",
    "vitest": "^4.1.2"
  },
  "build": {
    "appId": "com.marky.app",
    "productName": "Marky",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "appx",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "appx": {
      "identityName": "Marky",
      "publisher": "CN=Marky",
      "publisherDisplayName": "Marky",
      "applicationId": "Marky"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "appId": "io.github.marky_editor.marky",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icons",
      "category": "Office"
    }
  }
}
